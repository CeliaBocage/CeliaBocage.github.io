# Variables d'environnement — à définir dans Vercel (Settings → Environment Variables).
# NE JAMAIS committer les vraies valeurs. Copier ce fichier en .env pour du local.

# Base de données Turso (libSQL)
TURSO_DB_URL=libsql://votre-base.turso.io
TURSO_DB_TOKEN=YOUR_TURSO_TOKEN_HERE

# Mot de passe de l'espace admin (/navigation/admin.html).
# Sans cette variable, l'admin est désactivé et toute écriture est refusée.
# Choisir un mot de passe long et unique.
ADMIN_PASSWORD=YOUR_ADMIN_PASSWORD_HERE
